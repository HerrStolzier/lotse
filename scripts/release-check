#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

echo "== Ruff =="
uv run ruff check src/ tests/
uv run ruff format --check src/ tests/

echo
echo "== Mypy =="
uv run mypy src/arkiv/ --ignore-missing-imports

echo
echo "== Core tests =="
uv run pytest tests/ -x -q

echo
echo "== Webhook plugin tests =="
uv pip install -e plugins/arkiv-webhook >/dev/null
uv run pytest --rootdir=plugins/arkiv-webhook \
  --override-ini="testpaths=plugins/arkiv-webhook/tests" \
  plugins/arkiv-webhook/tests/

echo
echo "Release check finished."
